[Unit]
Description=Venue FireWatch (secondary smoke/heat monitor)
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=david
WorkingDirectory=/home/david/venue-firewatch
EnvironmentFile=/home/david/venue-firewatch/.env
ExecStart=/home/david/venue-firewatch/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
