# Copy to .env and fill in. All vars are prefixed FW_.
# .env is gitignored — never commit real tokens.

# --- Web ---
FW_HOST=0.0.0.0
FW_PORT=8080

# --- Storage ---
FW_DB_PATH=data/firewatch.db

# --- MQTT (Mosquitto on localhost) ---
FW_MQTT_HOST=127.0.0.1
FW_MQTT_PORT=1883
# FW_MQTT_USERNAME=firewatch
# FW_MQTT_PASSWORD=change-me
FW_MQTT_BASE_TOPIC=zigbee2mqtt

# --- GatewayAPI (primary SMS) ---
# Get the token from your GatewayAPI dashboard. Sender max 11 chars.
FW_GATEWAYAPI_TOKEN=
FW_GATEWAYAPI_SENDER=FireWatch
FW_GATEWAYAPI_TIMEOUT_S=9

# --- TRM240 modem (secondary SMS) ---
# Default uses gammu. {to} and {text} are substituted.
# ModemManager alternative: point this at a wrapper that calls `mmcli`.
FW_MODEM_ENABLED=true
# FW_MODEM_SEND_CMD=gammu sendsms TEXT {to} -text {text!r}

# --- UPS (NUT). Leave unset to disable. ---
# FW_UPS_NAME=myups@localhost
FW_UPS_POLL_SECONDS=30

# --- Event mode safety backstop (hard cap on silent duration) ---
FW_EVENT_MAX_HOURS=8

# --- Dashboard auth ---
# Set a password to protect the dashboard. Leave empty to disable auth.
# FW_AUTH_PASSWORD=change-me-in-production
FW_AUTH_TOKEN_TTL_HOURS=24

# --- Balance check ---
FW_BALANCE_CHECK_INTERVAL_MINUTES=60
FW_BALANCE_WARN_THRESHOLD=10.0

# --- Escalation ---
# Minutes to wait for acknowledgment before escalating to the next recipient.
FW_ESCALATION_TIMEOUT_MINUTES=5

# --- Off-site watchdog heartbeat ---
# firewatch POSTs a beat here every interval; the off-site watchdog SMS-alerts
# if the beats stop. The token is normally set from the dashboard Settings page
# (stored in the db, overrides this env var) — leave FW_HEARTBEAT_TOKEN blank to
# manage it via the UI. The token must match the watchdog secret; never commit it.
FW_HEARTBEAT_ENABLED=true
FW_HEARTBEAT_URL=https://davidblikstad.no/heartbeat
FW_HEARTBEAT_TOKEN=
FW_HEARTBEAT_INTERVAL=300
